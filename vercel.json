{
  "version": 2,
  "buildCommand": "react-scripts build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "env": {
    "REACT_APP_MAPBOX_TOKEN_NEW": "@react_app_mapbox_token_new"
  }
}
